<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bola Interaktif</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        /* Animasi klik menggunakan CSS standar untuk transisi yang halus */
        .ball-active {
            transform: scale(1.2);
            background-color: #ef4444 !important; /* Berubah jadi merah */
        }
    </style>
</head>
<body class="bg-slate-900 h-screen w-screen overflow-hidden flex items-center justify-center select-none">

    <div id="canvas" class="relative w-full h-full">
        
        <div id="ball" class="absolute w-24 h-24 bg-sky-500 rounded-full shadow-lg shadow-sky-500/50 cursor-grab active:cursor-grabbing transition-transform duration-150 ease-out flex items-center justify-center text-white font-semibold text-sm">
            Seret Aku!
        </div>

    </div>

    <script>
        const ball = document.getElementById('ball');
        const canvas = document.getElementById('canvas');

        let isDragging = false;
        let offsetX, offsetY;

        // 1. Posisikan bola di tengah layar saat pertama kali dimuat
        function centerBall() {
            const canvasWidth = canvas.clientWidth;
            const canvasHeight = canvas.clientHeight;
            const ballWidth = ball.clientWidth;
            const ballHeight = ball.clientHeight;

            ball.style.left = `${(canvasWidth / 2) - (ballWidth / 2)}px`;
            ball.style.top = `${(canvasHeight / 2) - (ballHeight / 2)}px`;
        }
        
        // Jalankan fungsi tengahkan bola
        centerBall();
        // Update posisi jika ukuran browser diubah (resize)
        window.addEventListener('resize', centerBall);

        // 2. Logika Drag & Drop (Mouse)
        ball.addEventListener('mousedown', (e) => {
            isDragging = true;
            
            // Hitung jarak klik mouse dari ujung kiri dan atas bola
            offsetX = e.clientX - ball.getBoundingClientRect().left;
            offsetY = e.clientY - ball.getBoundingClientRect().top;
        });

        document.addEventListener('mousemove', (e) => {
            if (!isDragging) return;

            // Hitung posisi baru bola berdasarkan pergerakan mouse
            let x = e.clientX - canvas.getBoundingClientRect().left - offsetX;
            let y = e.clientY - canvas.getBoundingClientRect().top - offsetY;

            // Batasi agar bola tidak keluar dari batas layar (Boundary)
            const maxX = canvas.clientWidth - ball.clientWidth;
            const maxY = canvas.clientHeight - ball.clientHeight;

            x = Math.max(0, Math.min(x, maxX));
            y = Math.max(0, Math.min(y, maxY));

            ball.style.left = `${x}px`;
            ball.style.top = `${y}px`;
        });

        document.addEventListener('mouseup', () => {
            isDragging = false;
        });

        // 3. Logika Klik & Animasi (Click Event)
        ball.addEventListener('click', () => {
            // Tambahkan class animasi
            ball.classList.add('ball-active');
            ball.innerText = "Aw!";

            // Kembalikan ke ukuran dan warna semula setelah 200ms
            setTimeout(() => {
                ball.classList.remove('ball-active');
                ball.innerText = "Seret Aku!";
            }, 200);
        });

        // 4. Pendukung untuk Layar Sentuh / Touchscreen (HP/Tablet)
        ball.addEventListener('touchstart', (e) => {
            isDragging = true;
            const touch = e.touches[0];
            offsetX = touch.clientX - ball.getBoundingClientRect().left;
            offsetY = touch.clientY - ball.getBoundingClientRect().top;
        });

        document.addEventListener('touchmove', (e) => {
            if (!isDragging) return;
            const touch = e.touches[0];
            let x = touch.clientX - canvas.getBoundingClientRect().left - offsetX;
            let y = touch.clientY - canvas.getBoundingClientRect().top - offsetY;

            const maxX = canvas.clientWidth - ball.clientWidth;
            const maxY = canvas.clientHeight - ball.clientHeight;

            x = Math.max(0, Math.min(x, maxX));
            y = Math.max(0, Math.min(y, maxY));

            ball.style.left = `${x}px`;
            ball.style.top = `${y}px`;
        });

        document.addEventListener('touchend', () => {
            isDragging = false;
        });
    </script>
</body>
</html>
